@prefix : <https://w3id.org/hi-ontology#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix wd: <https://www.wikidata.org/entity/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ssn: <http://purl.oclc.org/NET/ssnx/ssn#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hcio: <urn:absolute:dev.nemo.inf.ufes.br/hcion/HCIO.owl#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix swrla: <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix caresses: <http://caressesrobot.org/ontology#> .
@base <https://w3id.org/hi-ontology#> .

<https://w3id.org/hi-ontology#> rdf:type owl:Ontology ;
                                 dc:description "Conceptual model of Hybrid Intelligence: agents, teams, goals, tasks, capabilities, methods, evaluations, context, and ethical phenomena."@en ;
                                 dc:license <https://creativecommons.org/licenses/by/4.0/> ;
                                 dc:title "The Hybrid Intelligence (HI) Ontology"@en ;
                                 dcterms:created "2025-10-01"^^xsd:date ;
                                 vann:preferredNamespacePrefix "hi" ;
                                 vann:preferredNamespaceUri "https://w3id.org/hi-ontology#" ;
                                 owl:versionInfo "2.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/license
dc:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://schema.org/name
schema:name rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  https://w3id.org/hi-ontology#hasInteractionIntentConcep
hi:hasInteractionIntentConcep rdf:type owl:AnnotationProperty .


###  https://w3id.org/hi-ontology#validatesAIOutput
hi:validatesAIOutput rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/hi-ontology#achievesOutcome
hi:achievesOutcome rdf:type owl:ObjectProperty ;
                   rdfs:domain hi:Agent ;
                   rdfs:range hi:Outcome ;
                   owl:propertyChainAxiom ( hi:performsAction
                                            hi:producesOutcome
                                          ) ;
                   rdfs:label "achieves outcome" .


###  https://w3id.org/hi-ontology#affectsAgent
hi:affectsAgent rdf:type owl:ObjectProperty ;
                rdfs:domain hi:Risk ;
                rdfs:range hi:Agent ;
                rdfs:label "affects agent" .


###  https://w3id.org/hi-ontology#allowsTask
hi:allowsTask rdf:type owl:ObjectProperty ;
              owl:inverseOf hi:requiresCapability ;
              rdfs:domain hi:Capability ;
              rdfs:range hi:Task ;
              rdfs:comment "A capability enables or allows a task to be performed."@en ;
              rdfs:label "allows task" .


###  https://w3id.org/hi-ontology#analyzesMedicalImage
hi:analyzesMedicalImage rdf:type owl:ObjectProperty ;
                        rdfs:domain hi:RadiotherapyAI ;
                        rdfs:range hi:MedicalImageAnalysisTask ;
                        rdfs:label "analyzes medical image"@en .


###  https://w3id.org/hi-ontology#annotatedBy
hi:annotatedBy rdf:type owl:ObjectProperty ;
               rdfs:domain hi:AnnotationEvaluation ;
               rdfs:range hi:HumanAnnotator ;
               rdfs:label "annotated by"@en .


###  https://w3id.org/hi-ontology#belongsToCohort
hi:belongsToCohort rdf:type owl:ObjectProperty ;
                   rdfs:domain hi:HumanAgent ;
                   rdfs:range hi:GenerationalCohort ;
                   rdfs:label "belongs to cohort"@en .


###  https://w3id.org/hi-ontology#categorizesAs
hi:categorizesAs rdf:type owl:ObjectProperty ;
                 rdfs:domain hi:TaskExecution ;
                 rdfs:range hi:MemoryCategory ;
                 rdfs:label "categorizes as"@en .


###  https://w3id.org/hi-ontology#communicatesWithHuman
hi:communicatesWithHuman rdf:type owl:ObjectProperty ;
                         owl:inverseOf hi:interactsWithAGV ;
                         rdfs:domain hi:AGV ;
                         rdfs:range hi:HumanAgent ;
                         rdfs:label "communicates with human"@en .


###  https://w3id.org/hi-ontology#conductedInEnvironment
hi:conductedInEnvironment rdf:type owl:ObjectProperty ;
                          rdfs:domain [ rdf:type owl:Class ;
                                        owl:unionOf ( hi:Experiment
                                                      hi:Task
                                                    )
                                      ] ;
                          rdfs:range hi:WarehouseEnvironment ;
                          rdfs:label "conducted in environment"@en .


###  https://w3id.org/hi-ontology#dependsOnCapability
hi:dependsOnCapability rdf:type owl:ObjectProperty ,
                                owl:TransitiveProperty ;
                       rdfs:domain hi:Capability ;
                       rdfs:range hi:Capability ;
                       rdfs:label "depends on capability" .


###  https://w3id.org/hi-ontology#doneBy
hi:doneBy rdf:type owl:ObjectProperty ;
          owl:inverseOf hi:performsAction ;
          rdfs:domain hi:Action ;
          rdfs:range hi:Agent ;
          rdfs:label "done by" .


###  https://w3id.org/hi-ontology#emergesFrom
hi:emergesFrom rdf:type owl:ObjectProperty ;
               rdfs:domain hi:Risk ;
               rdfs:range hi:UseCase ;
               rdfs:label "emerges from" .


###  https://w3id.org/hi-ontology#evaluatedBy
hi:evaluatedBy rdf:type owl:ObjectProperty ;
               rdfs:domain hi:TaskExecution ;
               rdfs:range hi:Evaluation ;
               rdfs:comment "Execution is evaluated by a defined evaluation."@en ;
               rdfs:label "evaluated by" .


###  https://w3id.org/hi-ontology#evaluatesTask
hi:evaluatesTask rdf:type owl:ObjectProperty ;
                 rdfs:domain hi:TrustEvaluation ;
                 rdfs:range hi:Task ;
                 rdfs:label "evaluates task"@en .


###  https://w3id.org/hi-ontology#executesTask
hi:executesTask rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf hi:isAssignedToTask ;
                rdfs:domain hi:Agent ;
                rdfs:range hi:Task ;
                owl:propertyChainAxiom ( hi:performsExecution
                                         hi:realizesTask
                                       ) ;
                rdfs:comment "Agent executes a task (derivable from Agent→Execution→Task)."@en ;
                rdfs:label "executes task" .


###  https://w3id.org/hi-ontology#experiencedInContext
hi:experiencedInContext rdf:type owl:ObjectProperty ;
                        rdfs:domain hi:Emotion ;
                        rdfs:range hi:Context ;
                        rdfs:label "experienced in context" .


###  https://w3id.org/hi-ontology#experiencesEmotion
hi:experiencesEmotion rdf:type owl:ObjectProperty ;
                      rdfs:domain hi:HumanAgent ;
                      rdfs:range hi:Emotion ;
                      rdfs:label "experiences emotion" .


###  https://w3id.org/hi-ontology#facilitatesStudy
hi:facilitatesStudy rdf:type owl:ObjectProperty ;
                    rdfs:domain hi:HCIExpert ;
                    rdfs:range hi:UsabilityStudy ;
                    rdfs:label "facilitates study"@en .


###  https://w3id.org/hi-ontology#feedsinto
hi:feedsinto rdf:type owl:ObjectProperty ;
             rdfs:domain hi:FeedbackLoop ;
             rdfs:range hi:Agent ;
             rdfs:label "feeds into" .


###  https://w3id.org/hi-ontology#hasAgentConcept
hi:hasAgentConcept rdf:type owl:ObjectProperty ;
                   rdfs:domain hi:Agent ;
                   rdfs:range skos:Concept ;
                   rdfs:comment "Links an agent to a concept in the HINT thesaurus."@en ;
                   rdfs:label "has agent concept" .


###  https://w3id.org/hi-ontology#hasAgentInvolved
hi:hasAgentInvolved rdf:type owl:ObjectProperty ;
                    rdfs:domain hi:Interaction ;
                    rdfs:range hi:Agent ;
                    rdfs:comment "Indicates an agent that participates in or contributes to an interaction episode. This property identifies the human or artificial agents involved in the exchange."@en ;
                    rdfs:label "has agent involved" .


###  https://w3id.org/hi-ontology#hasAgentLimitation
hi:hasAgentLimitation rdf:type owl:ObjectProperty ,
                               owl:AsymmetricProperty ;
                      rdfs:domain hi:Agent ;
                      rdfs:range hi:AgentLimitation ;
                      rdfs:label "has agent limitation" .


###  https://w3id.org/hi-ontology#hasCapability
hi:hasCapability rdf:type owl:ObjectProperty ;
                 owl:inverseOf hi:isCapabilityOf ;
                 rdfs:domain hi:Agent ;
                 rdfs:range hi:Capability ;
                 rdfs:comment "Agent possesses a capability."@en ;
                 rdfs:label "has capability" .


###  https://w3id.org/hi-ontology#hasCapabilityConcept
hi:hasCapabilityConcept rdf:type owl:ObjectProperty ;
                        rdfs:domain hi:Capability ;
                        rdfs:range skos:Concept ;
                        rdfs:comment "Links a capability to a concept in the HINT thesaurus."@en ;
                        rdfs:label "has capability concept" .


###  https://w3id.org/hi-ontology#hasConstraintConcept
hi:hasConstraintConcept rdf:type owl:ObjectProperty ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( hi:Agent
                                                    hi:Context
                                                    hi:HITeam
                                                  )
                                    ] ;
                        rdfs:range skos:Concept ;
                        rdfs:comment "Specifies the constraint using a concept in the HINT thesaurus."@en ;
                        rdfs:label "has constraint concept" .


###  https://w3id.org/hi-ontology#hasContextConcept
hi:hasContextConcept rdf:type owl:ObjectProperty ;
                     rdfs:domain hi:Context ;
                     rdfs:range skos:Concept ;
                     rdfs:comment "Links a context to a concept in the HINT thesaurus."@en ;
                     rdfs:label "has context concept" .


###  https://w3id.org/hi-ontology#hasDomainConcept
hi:hasDomainConcept rdf:type owl:ObjectProperty ;
                    rdfs:domain hi:UseCase ;
                    rdfs:range skos:Concept ;
                    rdfs:comment "Links a domain to a concept in the HINT thesaurus."@en ;
                    rdfs:label "has domain concept" .


###  https://w3id.org/hi-ontology#hasEthicalConsideration
hi:hasEthicalConsideration rdf:type owl:ObjectProperty ;
                           rdfs:domain hi:UseCase ;
                           rdfs:range hi:EthicalConsideration ;
                           rdfs:label "has ethical considerations" .


###  https://w3id.org/hi-ontology#hasEvaluationConcept
hi:hasEvaluationConcept rdf:type owl:ObjectProperty ;
                        rdfs:domain hi:Evaluation ;
                        rdfs:range skos:Concept ;
                        rdfs:comment "Links an evaluation to a concept in the HINT thesaurus."@en ;
                        rdfs:label "has evaluation concept" .


###  https://w3id.org/hi-ontology#hasExecutionConcept
hi:hasExecutionConcept rdf:type owl:ObjectProperty ;
                       rdfs:domain hi:TaskExecution ;
                       rdfs:range skos:Concept ;
                       rdfs:comment "Links an experiment to a concept in the HINT thesaurus."@en ;
                       rdfs:label "has execution concept" .


###  https://w3id.org/hi-ontology#hasExperiment
hi:hasExperiment rdf:type owl:ObjectProperty ;
                 rdfs:domain hi:Evaluation ;
                 rdfs:range hi:Experiment ;
                 rdfs:comment "An evaluation has an experiment."@en ;
                 rdfs:label "has experiment" .


###  https://w3id.org/hi-ontology#hasExperimentConcept
hi:hasExperimentConcept rdf:type owl:ObjectProperty ;
                        rdfs:domain hi:Experiment ;
                        rdfs:range skos:Concept ;
                        rdfs:comment "Links an experiment to a concept in the HINT thesaurus."@en ;
                        rdfs:label "has experiment concept" .


###  https://w3id.org/hi-ontology#hasGoal
hi:hasGoal rdf:type owl:ObjectProperty ;
           rdfs:domain hi:HITeam ;
           rdfs:range hi:Goal ;
           rdfs:comment "An HI team pursues one or more goals."@en ;
           rdfs:label "has goal" .


###  https://w3id.org/hi-ontology#hasGoalConcept
hi:hasGoalConcept rdf:type owl:ObjectProperty ;
                  rdfs:domain hi:Goal ;
                  rdfs:range skos:Concept ;
                  rdfs:comment "Links a goal to a concept in the HINT thesaurus."@en ;
                  rdfs:label "has goal concept" .


###  https://w3id.org/hi-ontology#hasHITeam
hi:hasHITeam rdf:type owl:ObjectProperty ;
             rdfs:domain hi:UseCase ;
             rdfs:range hi:HITeam ;
             rdfs:comment "A use case introduces a hybrid intelligence team."@en ;
             rdfs:label "has HI team" .


###  https://w3id.org/hi-ontology#hasInfluenceOn
hi:hasInfluenceOn rdf:type owl:ObjectProperty ;
                  owl:inverseOf hi:isInfluencedBy ;
                  rdfs:domain hi:Context ;
                  rdfs:range hi:HITeam ;
                  rdfs:comment "Relates a contextual condition to the HI team whose actions, collaboration dynamics, or task performance are influenced by that condition. It captures how background phenomena and constraints shape the team's operation in a given use case."@en ;
                  rdfs:label "has influence on" .


###  https://w3id.org/hi-ontology#hasInteractionEpisode
hi:hasInteractionEpisode rdf:type owl:ObjectProperty ;
                         rdfs:domain hi:TaskExecution ;
                         rdfs:range hi:Interaction ;
                         rdfs:comment "Identifies moments of interaction (e.g., dialogue, negotiation, or guidance) that unfold within the execution of a task."@en ;
                         rdfs:label "has interaction episode" .


###  https://w3id.org/hi-ontology#hasInteractionIntentConcept
hi:hasInteractionIntentConcept rdf:type owl:ObjectProperty ;
                               rdfs:domain hi:Interaction ;
                               rdfs:range skos:Concept ;
                               rdfs:comment "Intent underlying the interaction (e.g., explain, request, negotiate)."@en ;
                               rdfs:label "has interaction intent concept" .


###  https://w3id.org/hi-ontology#hasInteractionModalityConcept
hi:hasInteractionModalityConcept rdf:type owl:ObjectProperty ;
                                 rdfs:domain hi:Interaction ;
                                 rdfs:range skos:Concept ;
                                 rdfs:comment "Modality/channel used during the interaction."@en ;
                                 rdfs:label "has interaction modality concept" .


###  https://w3id.org/hi-ontology#hasKnowledge
hi:hasKnowledge rdf:type owl:ObjectProperty ;
                rdfs:domain hi:Agent ;
                rdfs:range hi:Knowledge ;
                rdfs:label "has knowledge" .


###  https://w3id.org/hi-ontology#hasLearningObjective
hi:hasLearningObjective rdf:type owl:ObjectProperty ;
                        rdfs:domain hi:Goal ;
                        rdfs:range hi:LearningObjective ;
                        rdfs:label "has learning objective" .


###  https://w3id.org/hi-ontology#hasMember
hi:hasMember rdf:type owl:ObjectProperty ;
             rdfs:domain hi:HITeam ;
             rdfs:range hi:Agent ;
             rdfs:comment "Specifies agents that are members of an HI team."@en ;
             rdfs:label "has member" .


###  https://w3id.org/hi-ontology#hasMethodConcept
hi:hasMethodConcept rdf:type owl:ObjectProperty ;
                    rdfs:domain hi:TaskExecution ;
                    rdfs:range skos:Concept ;
                    rdfs:comment "Links a task execution to a method in the HINT thesaurus."@en ;
                    rdfs:label "has method concept" .


###  https://w3id.org/hi-ontology#hasMetricConcept
hi:hasMetricConcept rdf:type owl:ObjectProperty ;
                    rdfs:domain hi:Evaluation ;
                    rdfs:range skos:Concept ;
                    rdfs:comment "An evaluation uses certain metrics, defined in the HINT thesaurus"@en ;
                    rdfs:label "has metric concept" .


###  https://w3id.org/hi-ontology#hasMetricTested
hi:hasMetricTested rdf:type owl:ObjectProperty ;
                   rdfs:domain hi:Experiment ;
                   rdfs:range skos:Concept ;
                   rdfs:comment "An experiment tests certain metrics, defined in the HINT thesaurus"@en ;
                   rdfs:label "has metric tested" .


###  https://w3id.org/hi-ontology#hasPhenomenonConcept
hi:hasPhenomenonConcept rdf:type owl:ObjectProperty ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( hi:Agent
                                                    hi:Context
                                                    hi:HITeam
                                                  )
                                    ] ;
                        rdfs:range skos:Concept ;
                        rdfs:comment "Context exhibits a phenomenon (e.g., bias/feedback emerges in that context)."@en ;
                        rdfs:label "has phenomenon concept" .


###  https://w3id.org/hi-ontology#hasRoleConcept
hi:hasRoleConcept rdf:type owl:ObjectProperty ;
                  rdfs:domain hi:Agent ;
                  rdfs:range skos:Concept ;
                  rdfs:comment "Links a role to a concept in the HINT thesaurus."@en ;
                  rdfs:label "has role concept" .


###  https://w3id.org/hi-ontology#hasTaskConcept
hi:hasTaskConcept rdf:type owl:ObjectProperty ;
                  rdfs:domain hi:Task ;
                  rdfs:range skos:Concept ;
                  rdfs:comment "Links a task to a concept in the HINT thesaurus."@en ;
                  rdfs:label "has task concept" .


###  https://w3id.org/hi-ontology#hasUseCaseConcept
hi:hasUseCaseConcept rdf:type owl:ObjectProperty ;
                     rdfs:domain hi:UseCase ;
                     rdfs:range skos:Concept ;
                     rdfs:comment "Links a use case to a concept in the HINT thesaurus."@en ;
                     rdfs:label "has use case concept" .


###  https://w3id.org/hi-ontology#identifiesError
hi:identifiesError rdf:type owl:ObjectProperty ;
                   rdfs:domain hi:AnnotationEvaluation ;
                   rdfs:range hi:ErrorCategory ;
                   rdfs:label "identifies error"@en .


###  https://w3id.org/hi-ontology#integratedIntoPlatform
hi:integratedIntoPlatform rdf:type owl:ObjectProperty ;
                          rdfs:domain hi:RadiotherapyAI ;
                          rdfs:range hi:DataPlatformContext ;
                          rdfs:label "integrated into platform"@en .


###  https://w3id.org/hi-ontology#interactsWith
hi:interactsWith rdf:type owl:ObjectProperty ,
                          owl:SymmetricProperty ;
                 rdfs:domain hi:Agent ;
                 rdfs:range hi:Agent ;
                 owl:propertyChainAxiom ( hi:performsExecution
                                          hi:hasInteractionEpisode
                                          hi:hasAgentInvolved
                                        ) ;
                 rdfs:comment "Two agents that participate in a shared interaction" ;
                 rdfs:label "interacts with" .


###  https://w3id.org/hi-ontology#interactsWithAGV
hi:interactsWithAGV rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hi:interactsWith ;
                    rdfs:domain hi:HumanAgent ;
                    rdfs:range hi:AGV ;
                    rdfs:label "interacts with AGV"@en .


###  https://w3id.org/hi-ontology#interactsWithInterface
hi:interactsWithInterface rdf:type owl:ObjectProperty ;
                          rdfs:domain hi:Neurologist ;
                          rdfs:range hi:DiagnosticAI ;
                          rdfs:label "interacts with interface"@en .


###  https://w3id.org/hi-ontology#investigatesRadiotherapy
hi:investigatesRadiotherapy rdf:type owl:ObjectProperty ;
                            rdfs:domain hi:PreclinicalStudy ;
                            rdfs:range skos:Concept ;
                            rdfs:label "investigates radiotherapy"@en .


###  https://w3id.org/hi-ontology#involvesAction
hi:involvesAction rdf:type owl:ObjectProperty ;
                  owl:inverseOf hi:performedIn ;
                  rdfs:domain hi:TaskExecution ;
                  rdfs:range hi:Action ;
                  rdfs:label "involves action" .


###  https://w3id.org/hi-ontology#isAssignedToTask
hi:isAssignedToTask rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf hi:isEligibleForTask ;
                    rdfs:domain hi:Agent ;
                    rdfs:range hi:Task ;
                    owl:propertyChainAxiom ( hi:performsExecution
                                             hi:realizesTask
                                           ) ;
                    rdfs:comment "Relates an agent to a task that it is formally assigned to perform. Every assignment implies that the agent is eligible for that task."@en ;
                    rdfs:label "is assigned to task" .


###  https://w3id.org/hi-ontology#isCapabilityOf
hi:isCapabilityOf rdf:type owl:ObjectProperty ;
                  rdfs:label "is capability of" .


###  https://w3id.org/hi-ontology#isEligibleForTask
hi:isEligibleForTask rdf:type owl:ObjectProperty ;
                     rdfs:domain hi:Agent ;
                     rdfs:range hi:Task ;
                     owl:propertyChainAxiom ( hi:hasCapability
                                              hi:allowsTask
                                            ) ;
                     rdfs:comment "Relates an agent to a task it is eligible to perform, based on their capabilities. Assignment is a stricter, policy-level decision that presupposes eligibility."@en ;
                     rdfs:label "is eligible for task" .


###  https://w3id.org/hi-ontology#isExpertIn
hi:isExpertIn rdf:type owl:ObjectProperty ;
              rdfs:domain hi:Agent ;
              rdfs:range hi:ExpertiseDomain ;
              rdfs:label "is expert in" .


###  https://w3id.org/hi-ontology#isInfluencedBy
hi:isInfluencedBy rdf:type owl:ObjectProperty ;
                  rdfs:domain hi:HITeam ;
                  rdfs:range hi:Context ;
                  rdfs:comment "Related a HI Team to the contextual condition that affects its actions, collaboration dynamics, or task performance."@en ;
                  rdfs:label "is influenced by" .


###  https://w3id.org/hi-ontology#operatesInContext
hi:operatesInContext rdf:type owl:ObjectProperty ;
                     rdfs:domain hi:Agent ;
                     rdfs:range hi:Context ;
                     rdfs:comment "Specifies the context in which an HI team operates."@en ;
                     rdfs:label "operates in context" .


###  https://w3id.org/hi-ontology#participatesInStudy
hi:participatesInStudy rdf:type owl:ObjectProperty ;
                       rdfs:domain hi:DemographicCohort ;
                       rdfs:range hi:UserStudy ;
                       rdfs:label "participates in study"@en .


###  https://w3id.org/hi-ontology#performedBy
hi:performedBy rdf:type owl:ObjectProperty ;
               owl:inverseOf hi:performsExecution ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( hi:TaskExecution
                                         )
                           ] ;
               rdfs:range hi:Agent ;
               rdfs:comment "Execution performed by an agent."@en ;
               rdfs:label "performed by" .


###  https://w3id.org/hi-ontology#performedIn
hi:performedIn rdf:type owl:ObjectProperty ;
               rdfs:label "performed in" .


###  https://w3id.org/hi-ontology#performsAction
hi:performsAction rdf:type owl:ObjectProperty ;
                  rdfs:domain hi:Agent ;
                  rdfs:range hi:Action ;
                  rdfs:label "performs action" .


###  https://w3id.org/hi-ontology#performsExecution
hi:performsExecution rdf:type owl:ObjectProperty ;
                     rdfs:domain hi:Agent ;
                     rdfs:range hi:TaskExecution ;
                     rdfs:comment "Agent that performs a specific task execution."@en ;
                     rdfs:label "performs execution" .


###  https://w3id.org/hi-ontology#performsWarehouseTask
hi:performsWarehouseTask rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf hi:executesTask ;
                         rdfs:domain hi:WarehouseCollaborator ;
                         rdfs:range hi:LogisticsTask ;
                         rdfs:label "performs warehouse task"@en .


###  https://w3id.org/hi-ontology#predictsOutcomeOf
hi:predictsOutcomeOf rdf:type owl:ObjectProperty ;
                     rdfs:domain hi:RadiotherapyAI ;
                     rdfs:range hi:TreatmentPlanningTask ;
                     rdfs:label "predicts outcome of"@en .


###  https://w3id.org/hi-ontology#producesOutcome
hi:producesOutcome rdf:type owl:ObjectProperty ;
                   rdfs:domain hi:Action ;
                   rdfs:range hi:Outcome ;
                   rdfs:label "produces outcome" .


###  https://w3id.org/hi-ontology#providesBiologicalContext
hi:providesBiologicalContext rdf:type owl:ObjectProperty ;
                             rdfs:domain hi:MedicalResearcher ;
                             rdfs:range hi:RadiotherapyResearchTask ;
                             rdfs:label "provides biological context"@en .


###  https://w3id.org/hi-ontology#providesExplanation
hi:providesExplanation rdf:type owl:ObjectProperty ;
                       rdfs:domain hi:DiagnosticAI ;
                       rdfs:range skos:Concept ;
                       rdfs:label "provides explanation"@en .


###  https://w3id.org/hi-ontology#queriesMedicalDatabase
hi:queriesMedicalDatabase rdf:type owl:ObjectProperty ;
                          rdfs:domain hi:MedicalAISystem ;
                          rdfs:range hi:MedicalKnowledgeSource ;
                          rdfs:label "queries medical database"@en .


###  https://w3id.org/hi-ontology#realizedBy
hi:realizedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf hi:realizesTask ;
              rdfs:domain hi:Task ;
              rdfs:range hi:TaskExecution ;
              rdfs:comment "A task is realized through a task execution."@en ;
              rdfs:label "realized by" .


###  https://w3id.org/hi-ontology#realizesTask
hi:realizesTask rdf:type owl:ObjectProperty ;
                rdfs:domain hi:TaskExecution ;
                rdfs:range hi:Task ;
                rdfs:comment "Task execution realizes a task."@en ;
                rdfs:label "realizes task" .


###  https://w3id.org/hi-ontology#requiresCapability
hi:requiresCapability rdf:type owl:ObjectProperty ;
                      rdfs:domain hi:Task ;
                      rdfs:range hi:Capability ;
                      rdfs:comment "A task requires certain capabilities to be accomplished."@en ;
                      rdfs:label "requires cability" .


###  https://w3id.org/hi-ontology#requiresImageAnalysis
hi:requiresImageAnalysis rdf:type owl:ObjectProperty ;
                         rdfs:domain hi:PreclinicalStudy ;
                         rdfs:range hi:MedicalImageAnalysisTask ;
                         rdfs:label "requires image analysis"@en .


###  https://w3id.org/hi-ontology#requiresTask
hi:requiresTask rdf:type owl:ObjectProperty ;
                rdfs:domain hi:Goal ;
                rdfs:range hi:Task ;
                rdfs:comment "A goal requires one or more tasks to be fulfilled."@en ;
                rdfs:label "has task" .


###  https://w3id.org/hi-ontology#storesDataIn
hi:storesDataIn rdf:type owl:ObjectProperty ;
                rdfs:domain hi:PreclinicalStudy ;
                rdfs:range hi:DataPlatformContext ;
                rdfs:label "stores data in"@en .


###  https://w3id.org/hi-ontology#towardsGoal
hi:towardsGoal rdf:type owl:ObjectProperty ;
               rdfs:domain hi:TaskExecution ;
               rdfs:range hi:Goal ;
               rdfs:comment "Task execution towards a goal."@en ;
               rdfs:label "towards goal" .


###  https://w3id.org/hi-ontology#treatsPatient
hi:treatsPatient rdf:type owl:ObjectProperty ,
                          owl:IrreflexiveProperty ;
                 rdfs:domain hi:MedicalProfessional ;
                 rdfs:range hi:Patient ;
                 rdfs:label "treats patient"@en .


###  https://w3id.org/hi-ontology#usesDataset
hi:usesDataset rdf:type owl:ObjectProperty ;
               rdfs:domain hi:Evaluation ;
               rdfs:range hi:Dataset ;
               rdfs:label "uses dataset" .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/hi-ontology#annotatedErrorCount
hi:annotatedErrorCount rdf:type owl:DatatypeProperty ;
                       rdfs:domain hi:Evaluation ;
                       rdfs:range xsd:integer ;
                       rdfs:label "has annotated error count"@en .


###  https://w3id.org/hi-ontology#fMeasureScore
hi:fMeasureScore rdf:type owl:DatatypeProperty ;
                 rdfs:domain hi:Evaluation ;
                 rdfs:range xsd:decimal ;
                 rdfs:label "has F-measure score"@en .


###  https://w3id.org/hi-ontology#hasAlternativeHypothesis
hi:hasAlternativeHypothesis rdf:type owl:DatatypeProperty ;
                            rdfs:domain hi:Experiment ;
                            rdfs:range xsd:string ;
                            rdfs:comment "Stores the textual formulation of the alternative hypothesis of an experiment."@en ;
                            rdfs:label "has alternative hypothesis"@en .


###  https://w3id.org/hi-ontology#hasAutonomyDegree
hi:hasAutonomyDegree rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain hi:Agent ;
                     rdfs:range xsd:string ;
                     rdfs:label "has autonomy degree" .


###  https://w3id.org/hi-ontology#hasExperienceLevel
hi:hasExperienceLevel rdf:type owl:DatatypeProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain hi:HumanAgent ;
                      rdfs:range xsd:string ;
                      rdfs:label "has experience level" .


###  https://w3id.org/hi-ontology#hasNullHypothesis
hi:hasNullHypothesis rdf:type owl:DatatypeProperty ;
                     rdfs:domain hi:Experiment ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Stores the textual formulation of the null hypothesis of an experiment."@en ;
                     rdfs:label "has null hypothesis"@en .


#################################################################
#    Classes
#################################################################

###  http://caressesrobot.org/ontology#MedicalStaff
caresses:MedicalStaff rdf:type owl:Class .


###  http://purl.oclc.org/NET/ssnx/ssn#Device
ssn:Device rdf:type owl:Class .


###  http://purl.oclc.org/NET/ssnx/ssn#Output
ssn:Output rdf:type owl:Class .


###  http://purl.oclc.org/NET/ssnx/ssn#Process
ssn:Process rdf:type owl:Class .


###  http://schema.org/Organization
schema:Organization rdf:type owl:Class ;
                    rdfs:comment "A Schema.org class representing an organization such as an institution, company, or group."@en ;
                    rdfs:label "Organization"@en .


###  http://schema.org/PropertyValue
schema:PropertyValue rdf:type owl:Class ;
                     rdfs:comment "A Schema.org class representing a specific property-value pair, often used for metadata or structured descriptions."@en ;
                     rdfs:label "Property Value"@en .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class ;
             rdfs:comment "A SKOS concept representing a unit of thought, used for controlled vocabularies and thesauri."@en ;
             rdfs:label "Concept"@en .


###  http://www.w3.org/ns/prov#Activity
prov:Activity rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Agent
prov:Agent rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
prov:Entity rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Person
foaf:Person rdf:type owl:Class ;
            rdfs:comment "A human individual described using the FOAF vocabulary. Represents natural persons who may participate in, interact with, or be modeled within a Hybrid Intelligence scenario."@en ;
            rdfs:label "Person"@en .


###  https://w3id.org/hi-ontology#AGV
hi:AGV rdf:type owl:Class ;
       rdfs:subClassOf ssn:Device ,
                       hi:ArtificialAgent ;
       rdfs:label "Automated Guided Vehicle (AGV)"@en .


###  https://w3id.org/hi-ontology#AICapability
hi:AICapability rdf:type owl:Class ;
                rdfs:subClassOf hi:Capability ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty hi:isCapabilityOf ;
                                  owl:someValuesFrom hi:ArtificialAgent
                                ] ;
                rdfs:label "AI Capability" .


###  https://w3id.org/hi-ontology#Action
hi:Action rdf:type owl:Class ;
          rdfs:label "Action" ;
          skos:closeMatch wd:Q4026292 .


###  https://w3id.org/hi-ontology#Agent
hi:Agent rdf:type owl:Class ;
         rdfs:subClassOf prov:Agent ;
         owl:disjointUnionOf ( hi:ArtificialAgent
                               hi:HumanAgent
                             ) ;
         rdfs:comment "An autonomous entity capable of having roles, goals, and capabilities within a hybrid intelligence system."@en ;
         rdfs:label "Agent"@en .


###  https://w3id.org/hi-ontology#AgentLimitation
hi:AgentLimitation rdf:type owl:Class ;
                   rdfs:label "Agent Limitation" .


###  https://w3id.org/hi-ontology#AnnotationEvaluation
hi:AnnotationEvaluation rdf:type owl:Class ;
                        rdfs:subClassOf hi:Evaluation ;
                        rdfs:label "Annotation Evaluation"@en .


###  https://w3id.org/hi-ontology#ArtificialAgent
hi:ArtificialAgent rdf:type owl:Class ;
                   rdfs:subClassOf hi:Agent ,
                                   hcio:Interactive_Computer_System ;
                   owl:disjointWith hi:HumanAgent ;
                   rdfs:comment "An artificial or computational agent (robot, software, etc.) collaborating with human agents."@en ;
                   rdfs:label "Artificial Agent"@en .


###  https://w3id.org/hi-ontology#AssistiveRobot
hi:AssistiveRobot rdf:type owl:Class ;
                  rdfs:subClassOf hi:ArtificialAgent ;
                  rdfs:label "Assistive Robot"@en .


###  https://w3id.org/hi-ontology#Authenticity
hi:Authenticity rdf:type owl:Class ;
                rdfs:subClassOf hi:EthicalConsideration ;
                rdfs:label "Authenticity" .


###  https://w3id.org/hi-ontology#Author
hi:Author rdf:type owl:Class ;
          rdfs:subClassOf hi:HumanAgent .


###  https://w3id.org/hi-ontology#Authorship
hi:Authorship rdf:type owl:Class ;
              rdfs:subClassOf hi:EthicalConsideration ;
              rdfs:label "Authorship" .


###  https://w3id.org/hi-ontology#AutoethnographicStudy
hi:AutoethnographicStudy rdf:type owl:Class ;
                         rdfs:subClassOf hi:Experiment ;
                         rdfs:label "Autoetnographic Study" .


###  https://w3id.org/hi-ontology#BabyBoomer
hi:BabyBoomer rdf:type owl:Class ;
              rdfs:subClassOf hi:GenerationalCohort ;
              rdfs:label "Baby Boomer"@en .


###  https://w3id.org/hi-ontology#Bias
hi:Bias rdf:type owl:Class ;
        rdfs:subClassOf hi:AgentLimitation ;
        rdfs:label "Bias" ;
        skos:closeMatch wd:Q742736 .


###  https://w3id.org/hi-ontology#Capability
hi:Capability rdf:type owl:Class ;
              rdfs:comment "A skill, competence, or functional capacity that allows an agent to perform or enable a task."@en ;
              rdfs:label "Capability"@en .


###  https://w3id.org/hi-ontology#Child
hi:Child rdf:type owl:Class ;
         rdfs:subClassOf hi:HumanAgent ;
         rdfs:label "Child"@en .


###  https://w3id.org/hi-ontology#ClinicalAgent
hi:ClinicalAgent rdf:type owl:Class ;
                 rdfs:subClassOf caresses:MedicalStaff ,
                                 hi:HumanAgent ;
                 rdfs:label "Clinical Agent"@en .


###  https://w3id.org/hi-ontology#ClinicalEnvironment
hi:ClinicalEnvironment rdf:type owl:Class ;
                       rdfs:subClassOf hi:Context ;
                       rdfs:label "Clinical Environment"@en .


###  https://w3id.org/hi-ontology#ClinicalTranslationGoal
hi:ClinicalTranslationGoal rdf:type owl:Class ;
                           rdfs:subClassOf hi:Goal ;
                           rdfs:label "Clinical Translation Goal"@en .


###  https://w3id.org/hi-ontology#CollaborationTask
hi:CollaborationTask rdf:type owl:Class ;
                     rdfs:subClassOf hi:Task ;
                     rdfs:label "Collaboration Task" .


###  https://w3id.org/hi-ontology#Context
hi:Context rdf:type owl:Class ;
           rdfs:comment "Situational conditions (environmental, cultural, cognitive) under which tasks and evaluations occur."@en ;
           rdfs:label "Context"@en .


###  https://w3id.org/hi-ontology#DataPlatformContext
hi:DataPlatformContext rdf:type owl:Class ;
                       rdfs:subClassOf hi:Context ;
                       rdfs:label "Data Platform Context"@en .


###  https://w3id.org/hi-ontology#Dataset
hi:Dataset rdf:type owl:Class ;
           rdfs:subClassOf prov:Entity ;
           rdfs:label "Dataset" .


###  https://w3id.org/hi-ontology#Decision
hi:Decision rdf:type owl:Class ;
            rdfs:subClassOf hi:Action ;
            rdfs:label "Decision" ;
            skos:closeMatch wd:Q16513426 .


###  https://w3id.org/hi-ontology#DemographicCohort
hi:DemographicCohort rdf:type owl:Class ;
                     rdfs:subClassOf hi:Context ;
                     rdfs:label "Demographic Cohort"@en .


###  https://w3id.org/hi-ontology#DiagnosisTask
hi:DiagnosisTask rdf:type owl:Class ;
                 rdfs:subClassOf hi:Task .


###  https://w3id.org/hi-ontology#DiagnosticAI
hi:DiagnosticAI rdf:type owl:Class ;
                rdfs:subClassOf hi:ArtificialAgent ;
                rdfs:label "Diagnostic AI"@en .


###  https://w3id.org/hi-ontology#Emotion
hi:Emotion rdf:type owl:Class ;
           rdfs:label "Emotion" ;
           rdfs:seeAlso caresses:PhysicalAndMentalCondition .


###  https://w3id.org/hi-ontology#ErrorCategory
hi:ErrorCategory rdf:type owl:Class ;
                 rdfs:subClassOf skos:Concept ;
                 rdfs:label "Error Category"@en .


###  https://w3id.org/hi-ontology#EthicalConsideration
hi:EthicalConsideration rdf:type owl:Class ;
                        owl:disjointWith hi:Risk ;
                        rdfs:label "Ethical Consideration" .


###  https://w3id.org/hi-ontology#Evaluation
hi:Evaluation rdf:type owl:Class ;
              rdfs:comment "A process of assessing the quality or outcome of executions, methods, or goals."@en ;
              rdfs:label "Evaluation"@en .


###  https://w3id.org/hi-ontology#Experiment
hi:Experiment rdf:type owl:Class ;
              rdfs:comment "An empirical setup linked to an evaluation that tests metrics and hypotheses."@en ;
              rdfs:label "Experiment"@en .


###  https://w3id.org/hi-ontology#ExpertiseDomain
hi:ExpertiseDomain rdf:type owl:Class ;
                   rdfs:label "Expertise Domain" .


###  https://w3id.org/hi-ontology#Explanation
hi:Explanation rdf:type owl:Class ;
               rdfs:subClassOf hi:Action ;
               rdfs:label "Explanation" ;
               skos:closeMatch wd:Q7958 .


###  https://w3id.org/hi-ontology#FactChecker
hi:FactChecker rdf:type owl:Class ;
               rdfs:subClassOf hi:HumanAgent ;
               rdfs:label "Fact Checker" .


###  https://w3id.org/hi-ontology#FeedbackLoop
hi:FeedbackLoop rdf:type owl:Class ;
                rdfs:subClassOf hi:Action ;
                rdfs:label "Feedback Loop" ;
                skos:closeMatch wd:Q183635 .


###  https://w3id.org/hi-ontology#GenerationX
hi:GenerationX rdf:type owl:Class ;
               rdfs:subClassOf hi:GenerationalCohort ;
               rdfs:label "Generation X"@en .


###  https://w3id.org/hi-ontology#GenerationY
hi:GenerationY rdf:type owl:Class ;
               rdfs:subClassOf hi:GenerationalCohort ;
               rdfs:label "Generation Y"@en .


###  https://w3id.org/hi-ontology#GenerationZ
hi:GenerationZ rdf:type owl:Class ;
               rdfs:subClassOf hi:GenerationalCohort ;
               rdfs:label "Generation Z"@en .


###  https://w3id.org/hi-ontology#GenerationalCohort
hi:GenerationalCohort rdf:type owl:Class ;
                      rdfs:subClassOf hi:DemographicCohort ;
                      rdfs:label "Generational Cohort"@en .


###  https://w3id.org/hi-ontology#Goal
hi:Goal rdf:type owl:Class ;
        rdfs:subClassOf hcio:User_Goal ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty hi:requiresTask ;
                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass hi:Task
                        ] ;
        rdfs:comment "A desired outcome pursued by an HI team, requiring one or more tasks to be completed."@en ;
        rdfs:label "Goal"@en .


###  https://w3id.org/hi-ontology#HCIExpert
hi:HCIExpert rdf:type owl:Class ;
             rdfs:subClassOf hi:HumanAgent ;
             rdfs:label "HCI Expert"@en .


###  https://w3id.org/hi-ontology#HITeam
hi:HITeam rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty hi:hasMember ;
                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass hi:ArtificialAgent
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty hi:hasMember ;
                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass hi:HumanAgent
                          ] ;
          rdfs:comment "A hybrid intelligence team composed of human and artificial agents pursuing a shared goal."@en ;
          rdfs:label "HI Team"@en .


###  https://w3id.org/hi-ontology#HumanAgent
hi:HumanAgent rdf:type owl:Class ;
              rdfs:subClassOf foaf:Person ,
                              hi:Agent ,
                              hcio:User ;
              rdfs:comment "A human participant in the hybrid intelligence system, possessing cognitive and perceptual abilities."@en ;
              rdfs:label "Human Agent"@en ;
              rdfs:seeAlso caresses:Person .


###  https://w3id.org/hi-ontology#HumanAnnotator
hi:HumanAnnotator rdf:type owl:Class ;
                  rdfs:subClassOf hi:HumanAgent ;
                  rdfs:label "Human Annotator"@en .


###  https://w3id.org/hi-ontology#HumanCapability
hi:HumanCapability rdf:type owl:Class ;
                   rdfs:subClassOf hi:Capability ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty hi:isCapabilityOf ;
                                     owl:someValuesFrom hi:HumanAgent
                                   ] ;
                   rdfs:label "Human Capability" .


###  https://w3id.org/hi-ontology#HumanHumanInteraction
hi:HumanHumanInteraction rdf:type owl:Class ;
                         rdfs:subClassOf hi:Interaction ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty hi:hasAgentInvolved ;
                                           owl:allValuesFrom hi:HumanAgent
                                         ] ;
                         rdfs:label "Human-Human Interaction" .


###  https://w3id.org/hi-ontology#HybridInteraction
hi:HybridInteraction rdf:type owl:Class ;
                     rdfs:subClassOf hi:Interaction ,
                                     hcio:Human-Computer_Interaction ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty hi:hasAgentInvolved ;
                                       owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass hi:ArtificialAgent
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty hi:hasAgentInvolved ;
                                       owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass hi:HumanAgent
                                     ] ;
                     rdfs:label "Hybrid Interaction" .


###  https://w3id.org/hi-ontology#InVitroExperiment
hi:InVitroExperiment rdf:type owl:Class ;
                     rdfs:subClassOf hi:PreclinicalStudy ;
                     owl:disjointWith hi:InVivoExperiment ;
                     rdfs:label "In Vitro Experiment"@en .


###  https://w3id.org/hi-ontology#InVivoExperiment
hi:InVivoExperiment rdf:type owl:Class ;
                    rdfs:subClassOf hi:PreclinicalStudy ;
                    rdfs:label "In Vivo Experiment"@en .


###  https://w3id.org/hi-ontology#InformationCategorizationTask
hi:InformationCategorizationTask rdf:type owl:Class ;
                                 rdfs:subClassOf hi:Task ;
                                 rdfs:label "Information Categorization Task"@en .


###  https://w3id.org/hi-ontology#Interaction
hi:Interaction rdf:type owl:Class ;
               rdfs:subClassOf prov:Activity ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty hi:hasAgentInvolved ;
                                 owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                 owl:onClass hi:Agent
                               ] ;
               rdfs:comment "A multi-agent task execution where two or more agents coordinate (verbal, symbolic, or physical) toward a goal."@en ;
               rdfs:label "Interaction"@en .


###  https://w3id.org/hi-ontology#Knowledge
hi:Knowledge rdf:type owl:Class ;
             rdfs:label "Knowledge" .


###  https://w3id.org/hi-ontology#KnowledgeGap
hi:KnowledgeGap rdf:type owl:Class ;
                rdfs:subClassOf hi:AgentLimitation ;
                rdfs:label "Knowledge Gap" .


###  https://w3id.org/hi-ontology#LLMAgent
hi:LLMAgent rdf:type owl:Class ;
            rdfs:subClassOf hi:ArtificialAgent ;
            rdfs:label "Large Language Model Agent"@en ;
            skos:closeMatch wd:Q115305900 .


###  https://w3id.org/hi-ontology#Law
hi:Law rdf:type owl:Class ;
       rdfs:subClassOf hi:ExpertiseDomain ;
       skos:exactMatch wd:Q7748 .


###  https://w3id.org/hi-ontology#LearningObjective
hi:LearningObjective rdf:type owl:Class ;
                     rdfs:label "Learning Objective" .


###  https://w3id.org/hi-ontology#LegalAdvisor
hi:LegalAdvisor rdf:type owl:Class ;
                rdfs:subClassOf hi:HumanAgent ;
                rdfs:label "Legal Advisor" .


