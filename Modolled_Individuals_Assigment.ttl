###  https://w3id.org/hi-ontology#Annotation
hi:Annotation rdf:type owl:NamedIndividual ,
                       hi:AnnotationEvaluation ;
              hi:annotatedBy hi:Annotator_1 ,
                             hi:Annotator_2 ,
                             hi:Annotator_3 ,
                             hi:Annotator_4 ;
              hi:identifiesError hi:Error_CategoryBoundaries ,
                                 hi:Error_ImpliedInformation ,
                                 hi:Error_Importance ;
              hi:annotatedErrorCount 33 ;
              hi:fMeasureScore 0.38 ;
              rdfs:label "Annotation of Experiment"@en .


