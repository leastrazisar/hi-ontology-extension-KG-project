###  https://w3id.org/hi-ontology#AGV_Demo_Unit
hi:AGV_Demo_Unit rdf:type owl:NamedIndividual ,
                          hi:AGV ;
                 hi:conductedInEnvironment hi:MixedFleetWarehouse ;
                 hi:performsWarehouseTask hi:Task_PickAndPlace ;
                 rdfs:label "Demo AGV Unit"@en .


###  https://w3id.org/hi-ontology#AI_ColonyCounter
hi:AI_ColonyCounter rdf:type owl:NamedIndividual ,
                             hi:RadiotherapyAI ;
                    hi:analyzesMedicalImage hi:Task_CountCellColonies ;
                    hi:hasAgentConcept hint:ArtificialAgent ;
                    hi:integratedIntoPlatform hi:HPC_DataPlatform ;
                    rdfs:label "Deep Learning Colony Counter"@en .


###  https://w3id.org/hi-ontology#AI_DiagnosticAssistant
hi:AI_DiagnosticAssistant rdf:type owl:NamedIndividual ,
                                   hi:MedicalAISystem ;
                          hi:hasAgentConcept hint:ArtificialAgent ;
                          hi:hasRoleConcept hint:AIAssistantRole ;
                          hi:queriesMedicalDatabase hi:MedicalJournals ,
                                                    hi:PreviousTests ;
                          rdfs:label "Clinical Search and Analysis AI"@en .


###  https://w3id.org/hi-ontology#AI_GenerativeSuperResolution
hi:AI_GenerativeSuperResolution rdf:type owl:NamedIndividual ,
                                         hi:RadiotherapyAI ;
                                hi:analyzesMedicalImage hi:Task_GenerateSuperResolution ;
                                hi:hasAgentConcept hint:ArtificialAgent ;
                                hi:integratedIntoPlatform hi:HPC_DataPlatform ;
                                rdfs:label "AI for Super-Resolution"@en .


###  https://w3id.org/hi-ontology#AI_TreatmentPlanner
hi:AI_TreatmentPlanner rdf:type owl:NamedIndividual ,
                                hi:RadiotherapyAI ;
                       hi:integratedIntoPlatform hi:HPC_DataPlatform ;
                       hi:predictsOutcomeOf hi:Task_OptimizeTreatmentPlan ;
                       rdfs:label "Treatment Planner"@en .


###  https://w3id.org/hi-ontology#AI_TumorSegmenter
hi:AI_TumorSegmenter rdf:type owl:NamedIndividual ,
                              hi:RadiotherapyAI ;
                     hi:analyzesMedicalImage hi:Task_SegmentTumorUltrasound ;
                     hi:hasAgentConcept hint:ArtificialAgent ;
                     hi:integratedIntoPlatform hi:HPC_DataPlatform ;
                     rdfs:label "Deep Learning Tumor Segmenter"@en .


