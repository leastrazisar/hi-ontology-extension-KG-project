hi:MedicalImageAnalysisTask rdf:type owl:Class ;
                            rdfs:subClassOf hi:RadiotherapyResearchTask ;
                            rdfs:label "Medical Image Analysis Task"@en .


###  https://w3id.org/hi-ontology#MedicalKnowledgeSource
hi:MedicalKnowledgeSource rdf:type owl:Class ;
                          rdfs:subClassOf hi:Context ;
                          rdfs:label "Medical Knowledge Source" .


