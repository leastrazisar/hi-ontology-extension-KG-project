hi:Risk rdf:type owl:Class ;
        rdfs:label "Risk" .


###  https://w3id.org/hi-ontology#SocietalImpact
hi:SocietalImpact rdf:type owl:Class ;
                  rdfs:subClassOf hi:EthicalConsideration ;
                  rdfs:label "Societal Impact" .


###  https://w3id.org/hi-ontology#TacitKnowledge
hi:TacitKnowledge rdf:type owl:Class ;
                  rdfs:subClassOf hi:Knowledge ;
                  rdfs:label "Tacit Knowledge" .


###  https://w3id.org/hi-ontology#Task
hi:Task rdf:type owl:Class ;
        rdfs:subClassOf ssn:Process ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty hi:requiresCapability ;
                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass hi:Capability
                        ] ;
        rdfs:comment "A unit of purposeful activity executed by an agent toward achieving a goal."@en ;
        rdfs:label "Task"@en .


###  https://w3id.org/hi-ontology#TaskExecution
hi:TaskExecution rdf:type owl:Class ;
                 rdfs:subClassOf prov:Activity ;
                 rdfs:comment "The realization or performance of a specific task by an agent using a method."@en ;
                 rdfs:label "Task Execution"@en .


###  https://w3id.org/hi-ontology#TreatmentPlanningTask
hi:TreatmentPlanningTask rdf:type owl:Class ;
                         rdfs:subClassOf hi:RadiotherapyResearchTask ;
                         rdfs:label "Treatment Planning Task"@en .


###  https://w3id.org/hi-ontology#TrustEvaluation
hi:TrustEvaluation rdf:type owl:Class ;
                   rdfs:subClassOf hi:Evaluation ;
                   rdfs:label "Trust Evaluation"@en .


###  https://w3id.org/hi-ontology#UsabilityStudy
hi:UsabilityStudy rdf:type owl:Class ;
                  rdfs:subClassOf hi:Experiment ;
                  rdfs:label "Usability Study"@en .


###  https://w3id.org/hi-ontology#UseCase
hi:UseCase rdf:type owl:Class ;
           rdfs:comment "A structured situation describing a specific hybrid intelligence scenario (previously 'Scenario')."@en ;
           rdfs:label "Use Case"@en .


###  https://w3id.org/hi-ontology#UserStudy
hi:UserStudy rdf:type owl:Class ;
             rdfs:subClassOf hi:Experiment ;
             rdfs:label "User Study"@en .


###  https://w3id.org/hi-ontology#WarehouseCollaborator
hi:WarehouseCollaborator rdf:type owl:Class ;
                         owl:equivalentClass [ rdf:type owl:Class ;
                                               owl:unionOf ( hi:AGV
                                                             hi:WarehouseWorker
                                                           )
                                             ] ;
                         rdfs:label "Warehouse Collaborator"@en .


###  https://w3id.org/hi-ontology#WarehouseEnvironment
hi:WarehouseEnvironment rdf:type owl:Class ;
                        rdfs:subClassOf hi:Context ;
                        rdfs:label "Warehouse Environment"@en .


###  https://w3id.org/hi-ontology#WarehouseWorker
hi:WarehouseWorker rdf:type owl:Class ;
                   rdfs:subClassOf hi:HumanAgent ;
                   rdfs:label "Warehouse Worker"@en .


###  https://w3id.org/hi-ontology#WorkloadEvaluation
hi:WorkloadEvaluation rdf:type owl:Class ;
                      rdfs:subClassOf hi:Evaluation ;
                      rdfs:label "Workload Evaluation"@en .


###  urn:absolute:dev.nemo.inf.ufes.br/hcion/HCIO.owl#Human-Computer_Interaction
hcio:Human-Computer_Interaction rdf:type owl:Class .


###  urn:absolute:dev.nemo.inf.ufes.br/hcion/HCIO.owl#Interactive_Computer_System
hcio:Interactive_Computer_System rdf:type owl:Class .


###  urn:absolute:dev.nemo.inf.ufes.br/hcion/HCIO.owl#User
hcio:User rdf:type owl:Class .


###  urn:absolute:dev.nemo.inf.ufes.br/hcion/HCIO.owl#User_Goal
hcio:User_Goal rdf:type owl:Class .


