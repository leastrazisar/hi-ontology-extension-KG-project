hi:AI_assistance_use rdf:type owl:NamedIndividual ,
                              hi:Context ;
                     rdfs:label "Use of AI" .


###  https://w3id.org/hi-ontology#AI_driven_virtual_agent
hi:AI_driven_virtual_agent rdf:type owl:NamedIndividual ,
                                    hi:ArtificialAgent ;
                           hi:hasCapability hi:data_mining ,
                                            hi:pattern_recognition ;
                           hi:operatesInContext hi:academic_research_context ;
                           hi:performsExecution hi:analyse_AI_findings ;
                           rdfs:label "AI-driven virtual agent" .


