###  https://w3id.org/hi-ontology#Alex
hi:Alex rdf:type owl:NamedIndividual ,
                 hi:Child ;
        hi:belongsToCohort hi:Cohort_GenZ ;
        hi:experiencesEmotion hi:Motivation ;
        hi:operatesInContext hi:CollaborativeReadingContext ;
        hi:hasExperienceLevel "early reader with dyslexia" ;
        rdfs:label "Alex" .


