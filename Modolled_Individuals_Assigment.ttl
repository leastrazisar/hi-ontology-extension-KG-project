hi:Action_AdaptPlan rdf:type owl:NamedIndividual ,
                             hi:Recommendation ;
                    hi:doneBy hi:AssistiveRobot_1 ;
                    hi:producesOutcome hi:AdaptedReadingPlan ;
                    rdfs:label "Robot recommends reading adaptation" .


